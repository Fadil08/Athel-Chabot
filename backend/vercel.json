{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/../frontend/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/../frontend/dist/index.html"
    }
  ]
}
