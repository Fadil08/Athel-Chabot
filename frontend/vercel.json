{
  "rewrites": [
    {
      "source": "/widget.js",
      "destination": "https://athel-backend.vercel.app/widget.js"
    },
    {
      "source": "/api/:path*",
      "destination": "https://athel-backend.vercel.app/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
